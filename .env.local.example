# ============================================================
#  LakeLife — your secret keys live here
# ------------------------------------------------------------
#  HOW TO USE THIS FILE:
#  1. Make a COPY of this file named exactly ".env.local"
#     (Claude Code can do this for you — just ask.)
#  2. Paste each key from your keys notebook after the "=" sign.
#  3. Never share .env.local or commit it to GitHub. It stays
#     on your Mac only. (This file, the ".example" one, is safe.)
#
#  Anything starting with NEXT_PUBLIC_ is allowed in the browser.
#  Everything else is BACKEND-ONLY and must never appear in a
#  front-end file. If unsure where a key goes, ask Claude Code.
# ============================================================

# ---- Supabase (your database, logins, photo storage) -------
# From Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role key — MASTER KEY. Backend only. Never in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Twilio (the texting company, for phone verification) --
# From the Twilio Console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# From Twilio → Verify → your "LakeLife" service → Service SID
TWILIO_VERIFY_SERVICE_SID=
# The phone number you bought (used for alert texts in later phases)
TWILIO_PHONE_NUMBER=

# ---- Site URL (used by sign-in redirects) ------------------
# Local testing uses this. Change to your real domain when you go live.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
#  NOT needed for Phase 1 — leave blank for now.
#  You already have these keys; they get wired up in later phases.
# ============================================================
# ---- Resend (receipt & welcome emails) — Phase 2 -----------
# RESEND_API_KEY=
# ---- Google Maps (maps + drive times) — Phase 3/5 ----------
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---- Gate/door code encryption (Phase 2) --------------------
# 64 hex chars. Generate with: node -e "console.log(require(0,0,0).randomBytes(32).toString(0,0,0))"
GATE_ENCRYPTION_KEY=

# ---- Cron secret (Phase 7 — nightly routing & reminders) ----
# Protects the /api/cron/* endpoints so ONLY the scheduler can trigger them.
# Set the SAME value here and in Vercel → Settings → Environment Variables.
# Vercel Cron automatically sends it as "Authorization: Bearer <value>".
# If this is blank, the cron endpoints refuse every request (fail closed).
CRON_SECRET=

# Branded email sender (set once lakelife.ai is verified in Resend)
EMAIL_FROM="LakeLife <noreply@lakelife.ai>"

# AI comms (lib/ai.ts): personalized reply drafting runs in MOCK mode until
# this is set. Get a key at console.anthropic.com — then drafts use Claude.
ANTHROPIC_API_KEY=
